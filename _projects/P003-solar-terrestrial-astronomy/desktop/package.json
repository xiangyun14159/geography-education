{
  "name": "sun-earth-teaching",
  "version": "1.7.0",
  "description": "日地天文教学工具 - Windows Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "25.1.8"
  },
  "build": {
    "productName": "日地天文教学",
    "appId": "com.sunearth.teaching.desktop",
    "directories": {
      "output": "../outputs"
    },
    "files": [
      "main.js",
      "app/**/*"
    ],
    "win": {
      "icon": "app/icon.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "日地天文教学_v1.7_win64.exe"
    }
  }
}
